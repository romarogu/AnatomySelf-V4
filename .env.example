# AnatomySelf 环境变量配置示例
# 复制此文件为 .env 并填入您的真实配置

# ========== AI 配置 ==========
# 必填：您的 LLM API Key (如 DeepSeek, OpenAI 等)
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 选填：API 基础地址 (默认: https://api.openai.com/v1)
# DeepSeek: https://api.deepseek.com
LLM_BASE_URL=https://api.deepseek.com

# 选填：使用的模型名称 (默认: gpt-4.1-mini)
# DeepSeek: deepseek-chat
LLM_MODEL=deepseek-chat

# 选填：AI 温度参数 (默认: 0.7)
LLM_TEMPERATURE=0.7

# ========== 环境配置 ==========
# 选填：默认城市拼音，用于获取天气和花粉指数 (默认: Beijing)
DEFAULT_CITY=Beijing

# ========== 数据库配置 ==========
# 选填：SQLite 数据库文件路径 (默认: ./anatomy_self.db)
DATABASE_PATH=./anatomy_self.db

# ========== OCR 配置 ==========
# 选填：是否启用 OCR 功能 (默认: true)
OCR_ENABLED=true

# ========== 调试模式 ==========
# 选填：是否开启调试模式 (默认: false)
DEBUG_MODE=false
